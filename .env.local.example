# ============================================================
# 사자성어 학습 앱 - 환경변수 설정 가이드
# Vercel 배포 시: 대시보드 > Settings > Environment Variables 에 동일하게 입력
# ============================================================

# [필수] Supabase 프로젝트 설정
NEXT_PUBLIC_SUPABASE_URL=http://89.167.97.217:8003
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# [필수] Supabase Service Role Key (서버 전용 - 절대 NEXT_PUBLIC_ 붙이지 말 것!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# [필수] 입시내비 SSO HMAC 서명 시크릿 (openssl rand -hex 32)
AUTH_HMAC_SECRET=your-random-secret-key-here

# [필수] 입시내비 로그아웃 콜백용 공유 시크릿
IPSI_NAVI_LOGOUT_SECRET=your-logout-secret-here
