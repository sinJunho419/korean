[{"idiom":"사생결단","hanja":"死生決斷","meaning":"죽고 사는 것을 돌보지 않고 결판을 내겠다는 각오.","char_meanings":{"사":"죽을 사(死)","생":"살 생(生)","결":"결단할 결(決)","단":"끊을 단(斷)"},"level":"advanced","set_no":10,"example_sentence":"사생결단의 각오로 마지막 경기에 임했다."},{"idiom":"상부상조","hanja":"相扶相助","meaning":"서로 돕고 서로 도와준다는 뜻.","char_meanings":{"상":"서로 상(相)","부":"도울 부(扶)","조":"도울 조(助)"},"level":"advanced","set_no":10,"example_sentence":"이웃 간에 상부상조하는 것이 우리 전통 미덕이다."},{"idiom":"선견지명","hanja":"先見之明","meaning":"앞일을 미리 내다보는 밝은 지혜.","char_meanings":{"선":"먼저 선(先)","견":"볼 견(見)","지":"갈 지(之)","명":"밝을 명(明)"},"level":"advanced","set_no":10,"example_sentence":"그의 선견지명 덕분에 회사가 위기를 피할 수 있었다."},{"idiom":"언중유골","hanja":"言中有骨","meaning":"말 속에 뼈가 있다는 뜻으로, 예사로운 말 속에 깊은 뜻이 담겨 있음을 이르는 말.","char_meanings":{"언":"말씀 언(言)","중":"가운데 중(中)","유":"있을 유(有)","골":"뼈 골(骨)"},"level":"advanced","set_no":10,"example_sentence":"웃으며 한 말이지만 언중유골이라 뜨끔했다."},{"idiom":"교학상장","hanja":"敎學相長","meaning":"가르치고 배우면서 서로 성장한다는 뜻.","char_meanings":{"교":"가르칠 교(敎)","학":"배울 학(學)","상":"서로 상(相)","장":"자랄 장(長)"},"level":"advanced","set_no":10,"example_sentence":"교학상장의 정신으로 선생과 학생이 함께 발전해 나갔다."},{"idiom":"와해","hanja":"瓦解","meaning":"기와가 깨지듯 조직이나 체계가 무너져 흩어짐.","char_meanings":{"와":"기와 와(瓦)","해":"풀 해(解)"},"level":"advanced","set_no":10,"example_sentence":"내부 분열로 인해 조직이 와해되고 말았다."},{"idiom":"백문불여일견","hanja":"百聞不如一見","meaning":"백 번 듣는 것이 한 번 보는 것만 못하다는 뜻으로, 직접 경험하는 것이 중요함을 이르는 말.","char_meanings":{"백":"일백 백(百)","문":"들을 문(聞)","불":"아닐 불(不)","여":"같을 여(如)","일":"한 일(一)","견":"볼 견(見)"},"level":"advanced","set_no":10,"example_sentence":"백문불여일견이라 직접 가서 확인해 보는 것이 좋겠다."},{"idiom":"인자무적","hanja":"仁者無敵","meaning":"어진 사람은 적이 없다는 뜻으로, 인덕이 있는 사람은 모두가 따르므로 대적할 자가 없음을 이르는 말.","char_meanings":{"인":"어질 인(仁)","자":"놈 자(者)","무":"없을 무(無)","적":"대적할 적(敵)"},"level":"advanced","set_no":10,"example_sentence":"인자무적이라 했으니, 덕으로 사람을 이끌어야 한다."},{"idiom":"단사표음","hanja":"簞食瓢飮","meaning":"대그릇에 밥을 담고 표주박으로 물을 마신다는 뜻으로, 청빈한 생활","char_meanings":{"단":"대그릇 단(簞)","사":"밥 사(食)","표":"표주박 표(瓢)","음":"마실 음(飮)"},"level":"advanced","set_no":10,"example_sentence":"안회는 단사표음의 생활 속에서도 학문을 즐겼다."},{"idiom":"우수마발","hanja":"牛首馬髮","meaning":"소의 머리와 말의 털이라는 뜻으로, 뒤죽박죽 뒤섞여 갈피를 잡을 수 없음","char_meanings":{"우":"소 우(牛)","수":"머리 수(首)","마":"말 마(馬)","발":"털 발(髮)"},"level":"advanced","set_no":10,"example_sentence":"보고서가 우수마발이라 내용을 파악하기 어려웠다."}]